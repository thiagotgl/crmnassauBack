generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                 Int         @id @default(autoincrement())
  nome               String
  cpf                String      @unique
  email              String      @unique
  senha              String
  tipo               TipoUsuario
  ativo              Boolean     @default(true)
  autenticadorAtivo  Boolean     @default(false)
  segredo2FA         String?
  dataConfirmacao2FA DateTime?
  criadoEm           DateTime    @default(now())
  atualizadoEm       DateTime    @updatedAt
  historicos         Historico[]
  leads              Lead[]

  @@index([tipo])
  @@index([ativo])
  @@map("usuarios")
}

model Empresa {
  id           Int         @id @default(autoincrement())
  nome         String
  cnpj         String?     @unique
  telefone     String?
  email        String?
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  contatos     Contato[]
  historicos   Historico[]
  leads        Lead[]

  @@map("empresas")
}

model Contato {
  id           Int         @id @default(autoincrement())
  nome         String
  cpf          String?     @unique
  telefone     String?
  email        String?
  empresaId    Int?
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  empresa      Empresa?    @relation(fields: [empresaId], references: [id])
  historicos   Historico[]
  leads        Lead[]

  @@map("contatos")
}

model Historico {
  id        Int           @id @default(autoincrement())
  titulo    String?
  descricao String
  leadId    Int?
  tipo      TipoHistorico
  usuarioId Int
  contatoId Int?
  empresaId Int?
  criadoEm  DateTime      @default(now())
  contato   Contato?      @relation(fields: [contatoId], references: [id])
  empresa   Empresa?      @relation(fields: [empresaId], references: [id])
  lead      Lead?         @relation(fields: [leadId], references: [id])
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([contatoId])
  @@index([empresaId])
  @@index([tipo])
  @@map("historicos")
}

model Lead {
  id            Int         @id @default(autoincrement())
  ordem         Int         @default(0)
  nome          String
  telefone      String?
  email         String?
  origem        String?
  status        StatusLead  @default(novo)
  valorEstimado Float?
  usuarioId     Int
  contatoId     Int?
  empresaId     Int?
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt
  historicos    Historico[]
  contato       Contato?    @relation(fields: [contatoId], references: [id])
  empresa       Empresa?    @relation(fields: [empresaId], references: [id])
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])

  @@index([status, ordem])
  @@index([usuarioId])
  @@map("leads")
}

enum TipoUsuario {
  admin
  vendedor
  cliente
  supervisor
}

enum TipoHistorico {
  observacao
  ligacao
  whatsapp
  email
  alteracao_status
}

enum StatusLead {
  novo
  contato
  qualificado
  proposta
  negociacao
  fechado_ganho
  fechado_perdido
}
