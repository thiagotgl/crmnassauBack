{
  "name": "crmnassauback",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "vitest": {
    "test": {
      "environment": "node",
      "globals": true,
      "pool": "threads",
      "setupFiles": [
        "./tests/setup/testSetup.js"
      ],
      "include": [
        "tests/unit/**/*.test.js"
      ],
      "coverage": {
        "provider": "v8",
        "reporter": [
          "text",
          "html"
        ],
        "reportsDirectory": "./coverage"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiagotgl/crmnassauBack.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/thiagotgl/crmnassauBack/issues"
  },
  "homepage": "https://github.com/thiagotgl/crmnassauBack#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "nodemon": "^3.1.14",
    "vitest": "^2.1.8"
  }
}
